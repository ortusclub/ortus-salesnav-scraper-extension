{
  "manifest_version": 3,
  "name": "Ortus Sales Nav Scraper",
  "version": "3.5.1",
  "description": "API-driven openLink, premium, and company data — fixes missing fields",
  "permissions": [
    "activeTab",
    "tabs",
    "storage",
    "scripting",
    "alarms",
    "notifications",
    "identity"
  ],
  "host_permissions": [
    "https://www.linkedin.com/*",
    "https://script.google.com/*",
    "https://sheets.googleapis.com/*"
  ],
  "oauth2": {
    "client_id": "548090826069-2c096dc4139h0rbo004qcs5fjhi9e4ro.apps.googleusercontent.com",
    "scopes": [
      "https://www.googleapis.com/auth/spreadsheets"
    ]
  },
  "content_scripts": [
    {
      "matches": ["https://www.linkedin.com/*"],
      "js": ["interceptor.js"],
      "run_at": "document_start",
      "world": "MAIN"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
